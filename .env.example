# Binance KYC Bot Configuration
# Copy this file to .env and fill in your values

# Required: Telegram bot token from @BotFather
BINANCE_KYC_TELEGRAM_TOKEN=

# Run mode: demo (default) or production
BINANCE_KYC_MODE=demo

# Logging level: DEBUG, INFO, WARNING, ERROR
BINANCE_KYC_LOG_LEVEL=INFO

# Default language: en, zh, ja, ko
BINANCE_KYC_DEFAULT_LANGUAGE=en

# Session timeout in minutes
BINANCE_KYC_SESSION_TIMEOUT_MINUTES=30

# Data storage directory
BINANCE_KYC_DATA_DIR=data

# ── Production only ──────────────────────────────────────────
# Binance API credentials (required when MODE=production)
# BINANCE_KYC_API_KEY=
# BINANCE_KYC_API_SECRET=
# BINANCE_KYC_API_BASE_URL=https://api.binance.com

# ── Webhook (optional) ──────────────────────────────────────
# Set for production webhook mode; leave empty for polling mode
# BINANCE_KYC_TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
